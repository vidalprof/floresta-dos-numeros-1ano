 },
 {
  "id": "aula_intro_contar",
  "texto": "Vamos colher as frutinhas! Conta comigo, uma de cada vez.",
  "voz": "Antonio"
 },
 {
  "id": "aula_intro_ordenar",
  "texto": "Colhe na ordem! Começa pela primeira. Qual vem antes?",
  "voz": "Antonio"
 },
 {
  "id": "aula_intro_trazer_exato",
  "texto": "O Tico precisa de exatamente sete frutinhas na cesta. Vamos ajudar ele!",
  "voz": "Antonio"
 },
 {
  "id": "aula_intro_agrupar",
  "texto": "Agora a gente conta de dez em dez! Pega as sacolas cheias de dez.",
  "voz": "Antonio"
 },
 {
  "id": "aula_dica_contar",
  "texto": "Quantas a gente já colheu? Vamos ver juntos!",
  "voz": "Antonio"
 },
 {
  "id": "aula_dica_ordenar",
  "texto": "Qual vem primeiro agora? Procura a próxima!",
  "voz": "Antonio"
 },
 {
  "id": "aula_dica_trazer_exato",
  "texto": "Quantas ainda faltam pra chegar em sete?",
  "voz": "Antonio"
 },
 {
  "id": "aula_dica_agrupar",
  "texto": "Quantos grupos de dez a gente já tem?",
  "voz": "Antonio"
 },
 {
  "id": "aula_ordem",
  "texto": "Opa, essa não! Qual vem primeiro? Procura a próxima!",
  "voz": "Antonio"
 },
 {
  "id": "aula_demais",
  "texto": "Opa, essa sobrou! Pega uma de volta, por favor.",
  "voz": "Antonio"
 },
 {
  "id": "aula_falta",
  "texto": "Ainda falta um pouquinho. Traz mais uma!",
  "voz": "Antonio"
 },
 {
  "id": "aula_ok",
  "texto": "Isso! Agora tá certinho!",
  "voz": "Antonio"
 },
 {
  "id": "aula_ok_0",
  "texto": "Conseguimos! Colhemos três! Muito bem!",
  "voz": "Antonio"
 },
 {
  "id": "aula_ok_1",
  "texto": "Conseguimos! Colhemos cinco! Muito bem!",
  "voz": "Antonio"
 },
 {
  "id": "aula_ok_2",
  "texto": "Conseguimos! Tudo em ordem até o cinco! Muito bem!",
  "voz": "Antonio"
 },
 {
  "id": "aula_ok_3",
  "texto": "Conseguimos! Colhemos dez! Muito bem!",
  "voz": "Antonio"
 },
 {
  "id": "aula_ok_4",
  "texto": "Conseguimos! Exatamente sete! Você parou na hora certa!",
  "voz": "Antonio"
 },
 {
  "id": "aula_ok_5",
  "texto": "Conseguimos! Duas cestas de dez são vinte! Muito bem!",
  "voz": "Antonio"
 },
 {
  "id": "aula_ok_6",
  "texto": "Conseguimos! Três cestas de dez são trinta! A despensa tá cheia!",
  "voz": "Antonio"
 },
 {
  "id": "aula_fim",
  "texto": "Que colheita! Você contou de um até trinta! O Tico vai ter comida o inverno todo. Até a próxima aventura!",
  "voz": "Antonio"
 },
 {
  "id": "npc0",
  "texto": "Oi! Eu sou o Tico. O frio tá chegando e eu preciso guardar frutas, mas eu me perco pra contar! Vocês me ajudam a colher e contar as frutas do pomar?",
  "voz": "Donato"
 }
]
